# Local dev environment variables.
# Copy this file to .env and fill in all values, then run ./start.sh

# JWT signing secret — shared by all services (min 32 chars)
JWT_SECRET=

# PostgreSQL server admin (fakestore_admin) — used only during DB init to create all other accounts
PG_ADMIN_PASSWORD=

# Per-DB DDL accounts — used by Flyway migrations only
USERS_DB_ADMIN_PASSWORD=
ORDERS_DB_ADMIN_PASSWORD=
CATALOG_DB_ADMIN_PASSWORD=

# Per-DB app accounts — used by running services (CRUD3 only)
USERS_DB_PASSWORD=
ORDERS_DB_PASSWORD=
CATALOG_DB_PASSWORD=
