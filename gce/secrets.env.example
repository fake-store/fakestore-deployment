# Copy this file to secrets.env and fill in all values.
# secrets.env is gitignored and must never be committed.
#
# Usage:
#   cp secrets.env.example secrets.env
#   # edit secrets.env
#   ./vm-init.sh        (first time)
#   ./deploy-fakestore.sh <version>

# ── GCE settings ──────────────────────────────────────────────────────────────

# GCP project ID (not display name — the unique slug, e.g. fakestore-prod-123456)
GCP_PROJECT=

# Zone for the VM (e.g. us-central1-a)
VM_ZONE=us-central1-a

# VM instance name
VM_NAME=fakestore-vm

# Public domain name (used for nginx server_name and certbot)
DOMAIN=fakestore.route36.com

# Email for Let's Encrypt certificate notifications
CERTBOT_EMAIL=

# ── App secrets ───────────────────────────────────────────────────────────────

# JWT signing secret — ONE shared value used by all services (min 32 chars)
JWT_SECRET=

# PostgreSQL server admin — used only during DB init to create all other accounts
PG_ADMIN_PASSWORD=

# Per-DB DDL accounts — used by Flyway migrations only
USERS_DB_ADMIN_PASSWORD=
ORDERS_DB_ADMIN_PASSWORD=
CATALOG_DB_ADMIN_PASSWORD=
PAYMENTS_DB_ADMIN_PASSWORD=
SHIPPING_DB_ADMIN_PASSWORD=

# Per-DB app accounts — used by running services (read/write only)
USERS_DB_PASSWORD=
ORDERS_DB_PASSWORD=
CATALOG_DB_PASSWORD=
PAYMENTS_DB_PASSWORD=
SHIPPING_DB_PASSWORD=
